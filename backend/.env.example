NODE_ENV=production
PORT=5000

FRONTEND_URL=https://app.example.com
BACKEND_URL=https://api.example.com

REDIS_URL=rediss://default:password@your-redis-host:6379
DATABASE_URL=mongodb+srv://username:password@cluster.example.mongodb.net/sylphDB

JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

LOG_LEVEL=info
AI_QUEUE_PREFIX=sylph
AI_API_MAX_BATCH_SIZE=250
AI_JOB_BATCH_SIZE=25
AI_JOB_BACKOFF_MS=1000
AI_WORKER_RATE_LIMIT_MAX=20
AI_WORKER_RATE_LIMIT_DURATION_MS=1000
AI_WORKER_LOCK_DURATION_MS=120000
AI_WORKER_STALLED_INTERVAL_MS=60000
AI_WORKER_DRAIN_DELAY_SECONDS=5
AI_WORKER_LEADER_LOCK_TTL_MS=90000
AI_WORKER_LEADER_LOCK_RENEW_MS=30000
API_REQUEST_TIMEOUT_MS=1800
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_RETRY_DELAY_MS=250
REDIS_MAX_RETRY_DELAY_MS=2000
