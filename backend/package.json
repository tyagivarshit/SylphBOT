  "scripts": {
    "test": "npm run test:integration && npm run test:legacy",
    "test:integration": "npm run build && node dist/tests/integration/run-integration-tests.js",
    "test:legacy": "npm run build && node dist/tests/run-tests.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/ai.worker.ts",
    "build": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc",
    "prisma:generate": "npx prisma generate",
    "prisma:db:push": "npx prisma db push",
    "prisma:rollout:phase2b": "npm run prisma:generate && npm run prisma:db:push",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/ai.worker.js"
  },
