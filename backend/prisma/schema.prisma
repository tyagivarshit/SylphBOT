/* ======================================
ENUMS (ADD THIS)
====================================== */

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
  TRIAL
}

enum Currency {
  INR
  USD
}

enum BillingCycle {
  monthly
  yearly
}

enum PlanType {
  FREE
  BASIC
  PRO
  ELITE
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/* =====================================================
USER SYSTEM
===================================================== */

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String   @unique
  password          String
  role              String   @default("OWNER")

  phone     String?
  avatar    String?
  
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)

  tokenVersion      Int      @default(0)

  verifyToken       String?
  verifyTokenExpiry DateTime?

  resetToken        String?
  resetTokenExpiry  DateTime?

  notifications Notification[]

  /* WORKSPACE RELATION */
  businessId String?   @db.ObjectId
  business   Business? @relation("UserBusiness", fields: [businessId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /* OWNER RELATION (FIX) */
  ownedBusinesses Business[] @relation("BusinessOwner")

  refreshTokens     RefreshToken[]

  deletedAt DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/* =====================================================
BUSINESS
===================================================== */

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String

  ownerId       String   @db.ObjectId
  owner         User     @relation("BusinessOwner", fields: [ownerId], references: [id])

  /* WORKSPACE USERS */
  users         User[]   @relation("UserBusiness")

  clients       Client[]
  subscription  Subscription?
  leads         Lead[]
  usage         Usage[]
  invoices      Invoice[]

  commentTriggers CommentTrigger[]
  automationFlows AutomationFlow[]

  website   String?
  industry  String?
  teamSize  String?
  type      String?
  timezone  String?

  notifications Notification[]

  calendarConnections CalendarConnection[]
  bookingSlots        BookingSlot[]
  appointments        Appointment[]

  knowledgeBases KnowledgeBase[]

  createdAt     DateTime @default(now())
  deletedAt DateTime?

  @@index([ownerId])
}

/* =====================================================
CLIENT CONNECTIONS
===================================================== */

model Client {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  platform      String

  phoneNumberId String?  @unique
  pageId        String?  @unique

  accessToken   String

  /* AI TRAINING */

  aiTone            String?
  businessInfo      String?
  pricingInfo       String?
  faqKnowledge      String?
  salesInstructions String?

  leads         Lead[]
  commentTriggers CommentTrigger[]

  isActive      Boolean  @default(true)
  deletedAt     DateTime?

  createdAt     DateTime @default(now())

  @@unique([businessId, platform])
  @@index([businessId])
}

/* =====================================================
PLANS
===================================================== */

model Plan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  priceIdINR String?
  priceIdUSD String?
  type         String

  maxAiCalls   Int
  maxMessages  Int
  maxFollowups Int


  subscriptions Subscription[]

  @@index([type])
}

/* =====================================================
SUBSCRIPTIONS
===================================================== */

model Subscription {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId           String   @unique @db.ObjectId
  business             Business @relation(fields: [businessId], references: [id])

  planId               String   @db.ObjectId
  plan                 Plan     @relation(fields: [planId], references: [id])

  status               SubscriptionStatus @default(INACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  graceUntil DateTime?

  currentPeriodEnd     DateTime?

  currency             Currency?
  billingCycle         BillingCycle?

  isTrial              Boolean @default(false)
  trialUsed            Boolean @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

}

/* =====================================================
LEADS (CRM)
===================================================== */

model Lead {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  clientId       String?  @db.ObjectId
  client         Client?  @relation(fields: [clientId], references: [id])

  name           String?
  phone          String?
  instagramId    String?
  email          String?

  platform       String

  stage          String   @default("NEW")
  aiStage        String?  @default("NEW")

  isHumanActive Boolean @default(false)
  assignedAgentId String?

  intent         String?   // 🔹 AI Intent Detection

  unreadCount    Int      @default(0)
  leadScore      Int      @default(0)

  followupCount  Int      @default(0)
  lastFollowupAt DateTime?

  messages       Message[]
  memories       Memory[]
  summaries      ConversationSummary[]

  lastMessageAt  DateTime?

  appointments   Appointment[]
  conversationStates ConversationState[]
  automationExecutions AutomationExecution[]

  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  @@index([businessId])
  @@index([phone])
  @@index([instagramId])
  @@index([clientId])
}

/* =====================================================
MESSAGES
===================================================== */

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  content   String
  sender    String

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

/* =====================================================
AI MEMORY ENGINE
===================================================== */

model Memory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  key       String
  value     String

  createdAt DateTime @default(now())

  @@index([leadId])
}

/* =====================================================
CONVERSATION SUMMARY
===================================================== */

model ConversationSummary {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  summary   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

/* =====================================================
WEBHOOK EVENT DEDUPLICATION
===================================================== */

model WebhookEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  platform  String
  createdAt DateTime @default(now())

  @@index([platform])
}

/* =====================================================
INSTAGRAM COMMENT AUTOMATION
===================================================== */

model CommentTrigger {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  clientId   String   @db.ObjectId
  client     Client   @relation(fields: [clientId], references: [id])

  reelId     String
  keyword    String
  replyText  String

  commentReplyText String?

  aiPrompt   String?
  dmText String?

  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([clientId])
}

/* =====================================================
DM FUNNEL AUTOMATION SYSTEM
===================================================== */

model AutomationFlow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  name        String
  channel     String
  status      String   @default("ACTIVE")

  triggerType String
  triggerValue String?

  steps       AutomationStep[]
  executions  AutomationExecution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([channel])
}

model AutomationStep {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  flowId      String   @db.ObjectId
  flow        AutomationFlow @relation(fields: [flowId], references: [id])

  stepKey     String
  stepType    String

  message     String?
  condition   String?
  nextStep    String?

  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([flowId])
  @@index([stepKey])
}

model AutomationExecution {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  flowId      String   @db.ObjectId
  flow        AutomationFlow @relation(fields: [flowId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  currentStep String
  variables   Json?

  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@index([flowId])
}

/* =====================================================
USAGE TRACKING
===================================================== */

model Usage {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  month         Int
  year          Int

  aiCallsUsed   Int      @default(0)
  messagesUsed  Int      @default(0)
  followupsUsed Int      @default(0)

  @@unique([businessId, month, year])
  @@index([businessId])
}

/* =====================================================
REFRESH TOKENS
===================================================== */

model RefreshToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  token      String   @unique
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])

  userAgent  String?
  ip         String?

  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

/* =====================================================
STRIPE EVENTS
===================================================== */

model StripeEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  type      String 
  createdAt DateTime @default(now())
}

/* =====================================================
ENTERPRISE BOOKING SYSTEM
===================================================== */

model CalendarConnection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId   String   @db.ObjectId
  business     Business @relation(fields: [businessId], references: [id])

  provider     String

  accessToken  String
  refreshToken String

  expiryDate   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model BookingSlot {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId   String   @db.ObjectId
  business     Business @relation(fields: [businessId], references: [id])

  dayOfWeek    Int
  startTime    String
  endTime      String

  slotDuration Int      @default(30)
  bufferTime   Int      @default(0)
  timezone     String   @default("UTC")

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model Appointment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  leadId     String?  @db.ObjectId
  lead       Lead?    @relation(fields: [leadId], references: [id])

  name       String
  email      String?
  phone      String?

  startTime  DateTime
  endTime    DateTime

  status     String   @default("BOOKED")

  meetingLink String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([leadId])
}

/* =====================================================
AI CONVERSATION STATE ENGINE
===================================================== */

model ConversationState {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @unique @db.ObjectId   // ✅ ONLY THIS

  lead      Lead     @relation(fields: [leadId], references: [id])

  state     String
  context   String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* =====================================================
AI KNOWLEDGE BASE
===================================================== */

model KnowledgeBase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  title       String
  content     String

  embedding   Json?    // 🔹 Vector Embedding

  sourceType  String
  sourceUrl   String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}
model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  businessId  String?  @db.ObjectId
  business    Business? @relation(fields: [businessId], references: [id])

  type        String   // LEAD / MESSAGE / AUTOMATION / SYSTEM
  title       String?
  message     String

  link        String?  // redirect URL (🔥 important for UX)

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([read])
}
model NotificationSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique

  email     Boolean  @default(true)
  whatsapp  Boolean  @default(false)
  leads     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
/* =====================================================
INVOICES (🔥 BILLING CORE)
===================================================== */

model Invoice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId      String   @db.ObjectId
  business        Business @relation(fields: [businessId], references: [id])

  amount          Int      // total (including tax)
  subtotal        Int?     // before tax
  taxAmount       Int?     // Stripe tax
  taxType         String?  // GST / VAT

  currency        String
  status          String

  stripeInvoiceId String?
  invoiceNumber   String   @unique

  createdAt       DateTime @default(now())

  @@index([businessId])
  @@index([stripeInvoiceId])
}