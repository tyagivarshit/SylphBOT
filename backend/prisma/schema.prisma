generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/* =====================================================
USER SYSTEM
===================================================== */

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String   @unique
  archivedEmail     String?
  password          String
  role              String   @default("OWNER")

  phone     String?
  avatar    String?
  
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)

  tokenVersion      Int      @default(0)

  verifyToken       String?
  verifyTokenExpiry DateTime?

  resetToken        String?
  resetTokenExpiry  DateTime?

  notifications Notification[]

  /* WORKSPACE RELATION */
  businessId String?   @db.ObjectId
  business   Business? @relation("UserBusiness", fields: [businessId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /* OWNER RELATION (FIX) */
  ownedBusinesses Business[] @relation("BusinessOwner")

  refreshTokens     RefreshToken[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]

  deletedAt DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/* =====================================================
BUSINESS
===================================================== */

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String

  ownerId       String   @db.ObjectId
  owner         User     @relation("BusinessOwner", fields: [ownerId], references: [id])

  /* WORKSPACE USERS */
  users         User[]   @relation("UserBusiness")

  clients       Client[]
  leads         Lead[]
  usage         Usage[]
  usageDaily    UsageDaily[]
  addonBalances AddonBalance[]
  proposalLedgers ProposalLedger[]
  contractLedgers ContractLedger[]
  paymentIntentLedgers PaymentIntentLedger[]
  invoiceLedgers InvoiceLedger[]
  subscriptionLedgers SubscriptionLedger[]
  paymentAttemptLedgers PaymentAttemptLedger[]
  refundLedgers RefundLedger[]
  chargebackLedgers ChargebackLedger[]
  signatureLedgers SignatureLedger[]
  commercePolicies CommercePolicy[]
  pricingCatalogEntries PricingCatalog[]
  discountApprovalLedgers DiscountApprovalLedger[]
  revenueRecognitionLedgers RevenueRecognitionLedger[]
  commerceProviderCredentials CommerceProviderCredential[]
  manualCommerceOverrides ManualCommerceOverride[]
  taxComplianceLedgers TaxComplianceLedger[]

  commentTriggers CommentTrigger[]
  automationFlows AutomationFlow[]

  website   String?
  industry  String?
  teamSize  String?
  type      String?
  timezone  String?
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(1)
  demoCompleted       Boolean @default(false)
  onboardingDemoLeadId String? @db.ObjectId

  notifications Notification[]

  calendarConnections CalendarConnection[]
  calendarProviderCredentials CalendarProviderCredential[]
  bookingSlots        BookingSlot[]
  appointments        Appointment[]
  appointmentLedgers  AppointmentLedger[]
  availabilitySlots   AvailabilitySlot[]
  slotReservations    SlotReservationLedger[]
  appointmentPolicies AppointmentPolicy[]
  waitlistEntries     WaitlistLedger[]
  calendarSyncEntries CalendarSyncLedger[]
  externalSyncIdempotencyEntries ExternalSyncIdempotency[]
  manualCalendarOverrides ManualCalendarOverride[]
  meetingArtifacts    MeetingArtifactLedger[]
  appointmentReminders AppointmentReminderLedger[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  securityAlerts      SecurityAlert[]

  knowledgeBases KnowledgeBase[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  salesMessageVariants SalesMessageVariant[]
  salesOptimizationInsights SalesOptimizationInsight[]
  leadStateHistories LeadStateHistory[]
  leadIntelligenceProfiles LeadIntelligenceProfile[]
  customerRelationships CustomerRelationship[]
  autonomousOpportunities AutonomousOpportunity[]
  autonomousCampaigns AutonomousCampaign[]
  eventOutbox EventOutbox[]
  revenueTouchLedgerEntries RevenueTouchLedger[]
  consentLedgerEntries ConsentLedger[]
  capReservations AutonomousCapReservation[]
  channelHealthEntries ChannelHealth[]
  leadControlStates LeadControlState[]
  inboundInteractions InboundInteraction[]
  humanWorkQueues HumanWorkQueue[]
  receptionMemories ReceptionMemory[]
  humanRoleCapabilities HumanRoleCapability[]
  humanAvailabilityStates HumanAvailabilityState[]
  humanTakeoverLedgerEntries HumanTakeoverLedger[]
  humanEscalationRules HumanEscalationRule[]
  forecastLedgers ForecastLedger[]
  predictionLedgers PredictionLedger[]
  optimizationDecisionLedgers OptimizationDecisionLedger[]
  experimentLedgers ExperimentLedger[]
  recommendationLedgers RecommendationLedger[]
  anomalyLedgers AnomalyLedger[]
  simulationLedgers SimulationLedger[]
  modelRegistryLedgers ModelRegistryLedger[]
  featureSnapshotLedgers FeatureSnapshotLedger[]
  intelligencePolicies IntelligencePolicy[]
  manualIntelligenceOverrides ManualIntelligenceOverride[]

  createdAt     DateTime @default(now())
  deletedAt DateTime?

  @@index([ownerId])
}

/* =====================================================
CLIENT CONNECTIONS
===================================================== */

model Client {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  platform      String

  phoneNumberId String?  @unique
  pageId        String?  @unique

  accessToken   String

  /* AI TRAINING */

  aiTone            String?
  businessInfo      String?
  pricingInfo       String?
  faqKnowledge      String?
  salesInstructions String?

  leads         Lead[]
  commentTriggers CommentTrigger[]
  knowledgeBases KnowledgeBase[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  salesMessageVariants SalesMessageVariant[]
  salesOptimizationInsights SalesOptimizationInsight[]
  leadIntelligenceProfiles LeadIntelligenceProfile[]
  revenueTouchLedgerEntries RevenueTouchLedger[]
  inboundInteractions InboundInteraction[]

  isActive      Boolean  @default(true)
  deletedAt     DateTime?

  createdAt     DateTime @default(now())

  @@unique([businessId, platform])
  @@index([businessId])
}

/* =====================================================
PLANS
===================================================== */

model Plan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  priceIdINR String?
  priceIdUSD String?
  type String @unique

  maxAiCalls   Int
  maxMessages  Int
  maxFollowups Int

  earlyUsed    Int      @default(0)
  earlyLimit   Int      @default(20)

}

/* =====================================================
LEADS (CRM)
===================================================== */

model Lead {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  clientId       String?  @db.ObjectId
  client         Client?  @relation(fields: [clientId], references: [id])

  name           String?
  phone          String?
  instagramId    String?
  email          String?

  platform       String

  stage          String   @default("NEW")
  aiStage        String?  @default("NEW")
  revenueState   String   @default("COLD")

  isHumanActive Boolean @default(false)
  assignedAgentId String?

  intent         String?   // 🔹 AI Intent Detection

  unreadCount    Int      @default(0)
  leadScore      Int      @default(0)

  followupCount  Int      @default(0)
  lastFollowupAt DateTime?
  lastEngagedAt  DateTime?
  lastClickedAt  DateTime?
  lastBookedAt   DateTime?
  lastConvertedAt DateTime?
  lastLifecycleAt DateTime?
  intelligenceUpdatedAt DateTime?

  messages       Message[]
  memories       Memory[]
  summaries      ConversationSummary[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  leadStateHistories LeadStateHistory[]
  intelligenceProfile LeadIntelligenceProfile?
  customerRelationships CustomerRelationship[]
  autonomousOpportunities AutonomousOpportunity[]
  autonomousCampaigns AutonomousCampaign[]
  revenueTouchLedgerEntries RevenueTouchLedger[]
  consentLedgerEntries ConsentLedger[]
  capReservations AutonomousCapReservation[]
  channelHealthEntries ChannelHealth[]
  leadControlState LeadControlState?
  inboundInteractions InboundInteraction[]
  humanWorkQueues HumanWorkQueue[]
  receptionMemory ReceptionMemory?
  takeoverLedgerEntries HumanTakeoverLedger[]

  lastMessageAt  DateTime?

  appointments   Appointment[]
  appointmentLedgers AppointmentLedger[]
  appointmentReminders AppointmentReminderLedger[]
  waitlistEntries WaitlistLedger[]
  conversationStates ConversationState[]
  automationExecutions AutomationExecution[]

  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  @@index([businessId])
  @@index([phone])
  @@index([instagramId])
  @@index([clientId])
  @@index([businessId, lastBookedAt])
  @@index([businessId, lastConvertedAt])
  @@index([businessId, intelligenceUpdatedAt])
}

/* =====================================================
MESSAGES
===================================================== */

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  content   String
  sender    String

  metadata  Json? 

  createdAt DateTime @default(now())
  salesTracking SalesMessageTracking?
  conversionEvents ConversionEvent[]
  revenueTouchLedgerEntries RevenueTouchLedger[]

  @@index([leadId])
  @@index([createdAt])
}

/* =====================================================
REVENUE OPTIMIZATION ENGINE
===================================================== */

model SalesMessageVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  messageType String   @default("AI_REPLY")
  variantKey  String
  label       String

  tone         String
  ctaStyle     String
  messageLength String
  instructions String

  weight      Int      @default(1)
  impressions Int     @default(0)
  conversions Int     @default(0)
  conversionValue Float @default(0)

  isActive    Boolean  @default(true)
  isPromoted  Boolean  @default(false)

  trackings   SalesMessageTracking[]
  conversionEvents ConversionEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, clientId, messageType, variantKey])
  @@index([businessId, clientId])
  @@index([messageType, isActive])
  @@index([isPromoted])
}

model SalesMessageTracking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  messageId   String   @unique @db.ObjectId
  message     Message  @relation(fields: [messageId], references: [id])

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  variantId   String?  @db.ObjectId
  variant     SalesMessageVariant? @relation(fields: [variantId], references: [id])

  source      String   @default("AI_ROUTER")
  cta         String?
  angle       String?
  leadState   String?
  messageType String   @default("AI_REPLY")
  traceId     String?
  metadata    Json?

  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversionEvents ConversionEvent[]

  @@index([businessId, sentAt])
  @@index([leadId])
  @@index([clientId])
  @@index([variantId])
  @@index([messageType])
}

model ConversionEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  messageId   String?  @db.ObjectId
  message     Message? @relation(fields: [messageId], references: [id])

  trackingId  String?  @db.ObjectId
  tracking    SalesMessageTracking? @relation(fields: [trackingId], references: [id])

  variantId   String?  @db.ObjectId
  variant     SalesMessageVariant? @relation(fields: [variantId], references: [id])

  touchLedgerId String? @db.ObjectId
  touchLedger   RevenueTouchLedger? @relation(fields: [touchLedgerId], references: [id])

  outcome     String
  value       Float?
  source      String?
  idempotencyKey String? @unique
  metadata    Json?

  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([businessId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([clientId])
  @@index([messageId])
  @@index([trackingId])
  @@index([touchLedgerId])
  @@index([variantId])
  @@index([outcome])
}

model SalesOptimizationInsight {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  insightType String
  summary     String
  recommendedTone String?
  recommendedCTAStyle String?
  recommendedMessageLength String?
  bestMessages Json?
  worstMessages Json?
  recommendations Json?
  sampleSize   Int      @default(0)
  confidence   Float    @default(0)
  expiresAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId, createdAt])
  @@index([clientId])
  @@index([insightType])
}

model LeadStateHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  previousState String?
  nextState     String
  reason        String
  scoreDelta    Int      @default(0)
  metadata      Json?

  createdAt     DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([leadId, createdAt])
  @@index([nextState])
}

model LeadIntelligenceProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @unique @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  intelligenceVersion String @default("phase2")
  profileCompleteness Float  @default(0)
  identityConfidence  Float  @default(0)
  relationshipHealth  Float  @default(0)

  engagementScore     Int    @default(0)
  qualificationScore  Int    @default(0)
  buyingIntentScore   Int    @default(0)
  lifecycleScore      Int    @default(0)
  behaviorScore       Int    @default(0)
  valueScore          Int    @default(0)
  churnScore          Int    @default(0)
  relationshipScore   Int    @default(0)
  compositeScore      Int    @default(0)

  lifecycleStage      String
  lifecycleStatus     String
  predictedBehavior   String
  nextBestAction      String
  valueTier           String
  churnRisk           String

  segmentKeys         String[]
  primarySegment      String?
  relationshipSummary String?

  enrichment      Json?
  metrics         Json?
  behavior        Json?
  valueModel      Json?
  lifecycle       Json?
  relationshipMap Json?

  lastLifecycleAt DateTime?
  lastActivityAt  DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, lifecycleStage])
  @@index([businessId, compositeScore])
  @@index([clientId])
  @@index([businessId, lastSyncedAt])
}

model CustomerRelationship {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  targetType        String
  targetId          String
  targetLabel       String?
  relationshipType  String
  strength          Int      @default(0)
  score             Int      @default(0)
  lifecycleStage    String?
  metadata          Json?
  lastObservedAt    DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([leadId, targetType, targetId])
  @@index([businessId, targetType])
  @@index([leadId, targetType])
  @@index([businessId, leadId, targetType, targetId])
  @@index([businessId, relationshipType])
}

model AutonomousOpportunity {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  leadId         String   @db.ObjectId
  lead           Lead     @relation(fields: [leadId], references: [id])

  opportunityKey String   @unique
  fingerprintVersion String @default("opp_fp_v1")
  fingerprintKey String   @default("")
  fingerprint    Json?
  snapshotVersion Int     @default(1)
  engine         String
  status         String   @default("PENDING")
  score          Int      @default(0)
  priority       String   @default("medium")
  title          String
  objective      String
  summary        String
  reason         String
  prompt         String?
  blockedReasons String[]
  guardrail      Json?
  context        Json?
  metrics        Json?
  recommendedAt  DateTime
  nextEligibleAt DateTime?
  lastEvaluatedAt DateTime @default(now())
  dispatchedAt   DateTime?
  closedAt       DateTime?
  supersededBy   String?  @db.ObjectId
  supersededAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([businessId, opportunityKey])
  @@index([businessId, engine])
  @@index([businessId, status])
  @@index([businessId, recommendedAt])
  @@index([businessId, leadId, engine, fingerprintVersion, fingerprintKey])
  @@index([businessId, leadId, engine, supersededBy])
  @@index([leadId, status])
}

model AutonomousCampaign {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  leadId         String   @db.ObjectId
  lead           Lead     @relation(fields: [leadId], references: [id])

  opportunityId  String?  @db.ObjectId
  engine         String
  status         String   @default("QUEUED")
  title          String
  objective      String
  prompt         String
  outreachMode   String   @default("DIRECT_MESSAGE")
  idempotencyKey String   @unique
  channel        String?
  traceId        String?
  aiJobId        String?
  cancelTokenVersion Int  @default(0)
  guardrail      Json?
  analytics      Json?
  metadata       Json?
  queuedAt       DateTime?
  dispatchedAt   DateTime?
  blockedAt      DateTime?
  failedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([businessId, engine, status])
  @@index([businessId, queuedAt])
  @@index([leadId, createdAt])
  @@index([opportunityId])
}

model EventOutbox {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String?  @db.ObjectId
  business      Business? @relation(fields: [businessId], references: [id])

  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  dedupeKey     String?  @unique

  createdAt     DateTime @default(now())
  publishedAt   DateTime?
  failedAt      DateTime?
  retries       Int      @default(0)
  lastError     String?

  consumerCheckpoints EventConsumerCheckpoint[]

  @@index([eventType, createdAt])
  @@index([publishedAt, failedAt, createdAt])
  @@index([aggregateType, aggregateId, createdAt])
}

model EventConsumerCheckpoint {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId

  eventOutboxId String  @db.ObjectId
