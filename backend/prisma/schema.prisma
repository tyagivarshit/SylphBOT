generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String   @unique
  password      String
  role          String   @default("OWNER")

  isVerified    Boolean  @default(false)   
  verifyToken   String?            
  verifyTokenExpiry DateTime?

  businesses    Business[]
  refreshTokens RefreshToken[] 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  ownerId       String   @db.ObjectId
  owner         User     @relation(fields: [ownerId], references: [id])

  clients       Client[]
  subscription  Subscription?
  leads         Lead[]
  usage         Usage[]   // ✅ changed to array for monthly tracking

  createdAt     DateTime @default(now())
}

model Client {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  platform      String
  phoneNumberId String?  @unique
  pageId        String?  @unique
  accessToken   String

  aiTone        String?
  businessInfo  String?
  pricingInfo   String?

  leads         Lead[]
  isActive      Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())

  @@unique([businessId, platform])
}

model Plan {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  priceId       String?  @unique   // Stripe price id
  maxAiCalls    Int
  maxMessages   Int
  maxFollowups  Int

  subscriptions Subscription[]
}

model Subscription {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId           String   @unique @db.ObjectId
  business             Business @relation(fields: [businessId], references: [id])

  planId               String   @db.ObjectId
  plan                 Plan     @relation(fields: [planId], references: [id])

  status String @default("INACTIVE") // ACTIVE, CANCELLED, PAST_DUE
  stripeCustomerId String?
  stripeSubscriptionId String? 
  currentPeriodEnd     DateTime?

  createdAt            DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  clientId       String?  @db.ObjectId
  client         Client?  @relation(fields: [clientId], references: [id])

  name           String?
  phone          String?
  instagramId    String?
  email          String?

  platform       String
  stage          String   @default("NEW")

  followupCount  Int      @default(0)
  lastFollowupAt DateTime?

  messages       Message[]
  lastMessageAt  DateTime?
  createdAt      DateTime @default(now())
  deletedAt DateTime?
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  content   String
  sender    String
  createdAt DateTime @default(now())
}

model Usage {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  month         Int
  year          Int

  aiCallsUsed   Int      @default(0)
  messagesUsed  Int      @default(0)
  followupsUsed Int      @default(0)

  @@unique([businessId, month, year])  // ✅ monthly tracking
}
model RefreshToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  token      String   @unique
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}
model StripeEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  createdAt DateTime @default(now())
}