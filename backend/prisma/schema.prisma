/* ======================================
ENUMS (ADD THIS)
====================================== */

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
  TRIAL
}

enum Currency {
  INR
  USD
}

enum BillingCycle {
  monthly
  yearly
}

enum PlanType {
  FREE
  BASIC
  PRO
  ELITE
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/* =====================================================
USER SYSTEM
===================================================== */

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String   @unique
  archivedEmail     String?
  password          String
  role              String   @default("OWNER")

  phone     String?
  avatar    String?
  
  isVerified        Boolean  @default(false)
  isActive          Boolean  @default(true)

  tokenVersion      Int      @default(0)

  verifyToken       String?
  verifyTokenExpiry DateTime?

  resetToken        String?
  resetTokenExpiry  DateTime?

  notifications Notification[]

  /* WORKSPACE RELATION */
  businessId String?   @db.ObjectId
  business   Business? @relation("UserBusiness", fields: [businessId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /* OWNER RELATION (FIX) */
  ownedBusinesses Business[] @relation("BusinessOwner")

  refreshTokens     RefreshToken[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]

  deletedAt DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/* =====================================================
BUSINESS
===================================================== */

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  stripeCustomerId String?

  ownerId       String   @db.ObjectId
  owner         User     @relation("BusinessOwner", fields: [ownerId], references: [id])

  /* WORKSPACE USERS */
  users         User[]   @relation("UserBusiness")

  clients       Client[]
  subscription  Subscription?
  leads         Lead[]
  usage         Usage[]
  usageDaily    UsageDaily[]
  addonBalances AddonBalance[]
  invoices      Invoice[]

  commentTriggers CommentTrigger[]
  automationFlows AutomationFlow[]

  website   String?
  industry  String?
  teamSize  String?
  type      String?
  timezone  String?
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(1)
  demoCompleted       Boolean @default(false)
  onboardingDemoLeadId String? @db.ObjectId

  notifications Notification[]

  calendarConnections CalendarConnection[]
  bookingSlots        BookingSlot[]
  appointments        Appointment[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  securityAlerts      SecurityAlert[]

  knowledgeBases KnowledgeBase[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  salesMessageVariants SalesMessageVariant[]
  salesOptimizationInsights SalesOptimizationInsight[]
  leadStateHistories LeadStateHistory[]

  createdAt     DateTime @default(now())
  deletedAt DateTime?

  @@index([ownerId])
  @@index([stripeCustomerId])
}

/* =====================================================
CLIENT CONNECTIONS
===================================================== */

model Client {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  platform      String

  phoneNumberId String?  @unique
  pageId        String?  @unique

  accessToken   String

  /* AI TRAINING */

  aiTone            String?
  businessInfo      String?
  pricingInfo       String?
  faqKnowledge      String?
  salesInstructions String?

  leads         Lead[]
  commentTriggers CommentTrigger[]
  knowledgeBases KnowledgeBase[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  salesMessageVariants SalesMessageVariant[]
  salesOptimizationInsights SalesOptimizationInsight[]

  isActive      Boolean  @default(true)
  deletedAt     DateTime?

  createdAt     DateTime @default(now())

  @@unique([businessId, platform])
  @@index([businessId])
}

/* =====================================================
PLANS
===================================================== */

model Plan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  priceIdINR String?
  priceIdUSD String?
  type String @unique

  maxAiCalls   Int
  maxMessages  Int
  maxFollowups Int

  earlyUsed    Int      @default(0)
  earlyLimit   Int      @default(20)

  subscriptions Subscription[]

}

/* =====================================================
SUBSCRIPTIONS
===================================================== */

model Subscription {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId           String   @unique @db.ObjectId
  business             Business @relation(fields: [businessId], references: [id])

  planId               String   @db.ObjectId
  plan                 Plan     @relation(fields: [planId], references: [id])

  status               SubscriptionStatus @default(INACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  graceUntil DateTime?

  currentPeriodEnd     DateTime?

  currency             Currency?
  billingCycle         BillingCycle?

  isTrial              Boolean @default(false)
  trialUsed            Boolean @default(false)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

}

/* =====================================================
LEADS (CRM)
===================================================== */

model Lead {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId     String   @db.ObjectId
  business       Business @relation(fields: [businessId], references: [id])

  clientId       String?  @db.ObjectId
  client         Client?  @relation(fields: [clientId], references: [id])

  name           String?
  phone          String?
  instagramId    String?
  email          String?

  platform       String

  stage          String   @default("NEW")
  aiStage        String?  @default("NEW")
  revenueState   String   @default("COLD")

  isHumanActive Boolean @default(false)
  assignedAgentId String?

  intent         String?   // 🔹 AI Intent Detection

  unreadCount    Int      @default(0)
  leadScore      Int      @default(0)

  followupCount  Int      @default(0)
  lastFollowupAt DateTime?
  lastEngagedAt  DateTime?
  lastClickedAt  DateTime?
  lastBookedAt   DateTime?
  lastConvertedAt DateTime?

  messages       Message[]
  memories       Memory[]
  summaries      ConversationSummary[]
  salesMessageTrackings SalesMessageTracking[]
  conversionEvents ConversionEvent[]
  leadStateHistories LeadStateHistory[]

  lastMessageAt  DateTime?

  appointments   Appointment[]
  conversationStates ConversationState[]
  automationExecutions AutomationExecution[]

  createdAt      DateTime @default(now())
  deletedAt      DateTime?

  @@index([businessId])
  @@index([phone])
  @@index([instagramId])
  @@index([clientId])
}

/* =====================================================
MESSAGES
===================================================== */

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  content   String
  sender    String

  metadata  Json? 

  createdAt DateTime @default(now())
  salesTracking SalesMessageTracking?
  conversionEvents ConversionEvent[]

  @@index([leadId])
  @@index([createdAt])
}

/* =====================================================
REVENUE OPTIMIZATION ENGINE
===================================================== */

model SalesMessageVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  messageType String   @default("AI_REPLY")
  variantKey  String
  label       String

  tone         String
  ctaStyle     String
  messageLength String
  instructions String

  weight      Int      @default(1)
  impressions Int     @default(0)
  conversions Int     @default(0)
  conversionValue Float @default(0)

  isActive    Boolean  @default(true)
  isPromoted  Boolean  @default(false)

  trackings   SalesMessageTracking[]
  conversionEvents ConversionEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, clientId, messageType, variantKey])
  @@index([businessId, clientId])
  @@index([messageType, isActive])
  @@index([isPromoted])
}

model SalesMessageTracking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  messageId   String   @unique @db.ObjectId
  message     Message  @relation(fields: [messageId], references: [id])

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  variantId   String?  @db.ObjectId
  variant     SalesMessageVariant? @relation(fields: [variantId], references: [id])

  source      String   @default("AI_ROUTER")
  cta         String?
  angle       String?
  leadState   String?
  messageType String   @default("AI_REPLY")
  traceId     String?
  metadata    Json?

  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversionEvents ConversionEvent[]

  @@index([businessId, sentAt])
  @@index([leadId])
  @@index([clientId])
  @@index([variantId])
  @@index([messageType])
}

model ConversionEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  messageId   String?  @db.ObjectId
  message     Message? @relation(fields: [messageId], references: [id])

  trackingId  String?  @db.ObjectId
  tracking    SalesMessageTracking? @relation(fields: [trackingId], references: [id])

  variantId   String?  @db.ObjectId
  variant     SalesMessageVariant? @relation(fields: [variantId], references: [id])

  outcome     String
  value       Float?
  source      String?
  idempotencyKey String?
  metadata    Json?

  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([businessId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([clientId])
  @@index([messageId])
  @@index([trackingId])
  @@index([variantId])
  @@index([outcome])
  @@index([idempotencyKey])
}

model SalesOptimizationInsight {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  insightType String
  summary     String
  recommendedTone String?
  recommendedCTAStyle String?
  recommendedMessageLength String?
  bestMessages Json?
  worstMessages Json?
  recommendations Json?
  sampleSize   Int      @default(0)
  confidence   Float    @default(0)
  expiresAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId, createdAt])
  @@index([clientId])
  @@index([insightType])
}

model LeadStateHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  previousState String?
  nextState     String
  reason        String
  scoreDelta    Int      @default(0)
  metadata      Json?

  createdAt     DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([leadId, createdAt])
  @@index([nextState])
}

/* =====================================================
AI MEMORY ENGINE
===================================================== */

model Memory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  key       String
  value     String

  createdAt DateTime @default(now())

  @@index([leadId])
}

/* =====================================================
CONVERSATION SUMMARY
===================================================== */

model ConversationSummary {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @db.ObjectId
  lead      Lead     @relation(fields: [leadId], references: [id])

  summary   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

/* =====================================================
WEBHOOK EVENT DEDUPLICATION
===================================================== */

model WebhookEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  platform  String
  createdAt DateTime @default(now())

  @@index([platform])
}

/* =====================================================
INSTAGRAM COMMENT AUTOMATION
===================================================== */

model CommentTrigger {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  clientId   String   @db.ObjectId
  client     Client   @relation(fields: [clientId], references: [id])

  reelId     String
  keyword    String
  replyText  String

  commentReplyText String?

  aiPrompt   String?
  dmText String?

  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([clientId])
}

/* =====================================================
DM FUNNEL AUTOMATION SYSTEM
===================================================== */

model AutomationFlow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  name        String
  channel     String
  status      String   @default("ACTIVE")

  triggerType String
  triggerValue String?

  steps       AutomationStep[]
  executions  AutomationExecution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([channel])
}

model AutomationStep {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  flowId      String   @db.ObjectId
  flow        AutomationFlow @relation(fields: [flowId], references: [id])

  stepKey     String
  stepType    String

  message     String?
  condition   String?
  nextStep    String?

  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([flowId])
  @@index([stepKey])
}

model AutomationExecution {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  flowId      String   @db.ObjectId
  flow        AutomationFlow @relation(fields: [flowId], references: [id])

  leadId      String   @db.ObjectId
  lead        Lead     @relation(fields: [leadId], references: [id])

  currentStep String
  variables   Json?

  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@index([flowId])
}

/* =====================================================
USAGE TRACKING
===================================================== */

model Usage {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId    String   @db.ObjectId
  business      Business @relation(fields: [businessId], references: [id])

  month         Int
  year          Int

  aiCallsUsed   Int      @default(0)
  messagesUsed  Int      @default(0)
  followupsUsed Int      @default(0)

  @@unique([businessId, month, year])
  @@index([businessId])
}

model UsageDaily {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  feature    String
  dateKey    String
  count      Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, feature, dateKey])
  @@index([businessId, dateKey])
}

model AddonBalance {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  type       String
  balance    Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, type])
  @@index([businessId])
}

/* =====================================================
REFRESH TOKENS
===================================================== */

model RefreshToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  token      String   @unique
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])

  userAgent  String?
  ip         String?

  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model ApiKey {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  key             String   @unique
  encryptedKey    String
  prefix          String
  name            String?
  permissions     String[]
  scopes          Json?

  businessId      String   @db.ObjectId
  business        Business @relation(fields: [businessId], references: [id])

  createdByUserId String?  @db.ObjectId
  createdByUser   User?    @relation(fields: [createdByUserId], references: [id])

  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([businessId, revokedAt])
  @@index([createdByUserId])
}

model AuditLog {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId

  userId     String?   @db.ObjectId
  user       User?     @relation(fields: [userId], references: [id])

  businessId String?   @db.ObjectId
  business   Business? @relation(fields: [businessId], references: [id])

  action     String
  metadata   Json?
  ip         String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime  @default(now())

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SecurityAlert {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  type       String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, type, createdAt])
}

/* =====================================================
STRIPE EVENTS
===================================================== */

model StripeEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  type      String 
  createdAt DateTime @default(now())
}

model BillingEvent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  stripeEventId String   @unique
  createdAt     DateTime @default(now())
}

/* =====================================================
ENTERPRISE BOOKING SYSTEM
===================================================== */

model CalendarConnection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId   String   @db.ObjectId
  business     Business @relation(fields: [businessId], references: [id])

  provider     String

  accessToken  String
  refreshToken String

  expiryDate   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model BookingSlot {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId   String   @db.ObjectId
  business     Business @relation(fields: [businessId], references: [id])

  dayOfWeek    Int
  startTime    String
  endTime      String

  slotDuration Int      @default(30)
  bufferTime   Int      @default(0)
  timezone     String   @default("UTC")

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model Appointment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId String   @db.ObjectId
  business   Business @relation(fields: [businessId], references: [id])

  leadId     String?  @db.ObjectId
  lead       Lead?    @relation(fields: [leadId], references: [id])

  name       String
  email      String?
  phone      String?

  startTime  DateTime
  endTime    DateTime

  status     String   @default("BOOKED")

  meetingLink String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([leadId])
}

/* =====================================================
AI CONVERSATION STATE ENGINE
===================================================== */

model ConversationState {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  leadId    String   @unique @db.ObjectId   // ✅ ONLY THIS

  lead      Lead     @relation(fields: [leadId], references: [id])

  state     String
  context   String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* =====================================================
AI KNOWLEDGE BASE
===================================================== */

model KnowledgeBase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId  String   @db.ObjectId
  business    Business @relation(fields: [businessId], references: [id])

  clientId    String?  @db.ObjectId
  client      Client?  @relation(fields: [clientId], references: [id])

  title       String
  content     String

  embedding   Json?

  sourceType  String
  sourceUrl   String?
  priority String @default("MEDIUM")

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([clientId])
  @@index([businessId, clientId])

  @@index([businessId, clientId, title])
}
model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  businessId  String?  @db.ObjectId
  business    Business? @relation(fields: [businessId], references: [id])

  type        String   // LEAD / MESSAGE / AUTOMATION / SYSTEM
  title       String?
  message     String

  link        String?  // redirect URL (🔥 important for UX)

  read        Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([read])
}
model NotificationSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique

  email     Boolean  @default(true)
  whatsapp  Boolean  @default(false)
  leads     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
/* =====================================================
INVOICES (🔥 BILLING CORE)
===================================================== */

model Invoice {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId

  businessId      String   @db.ObjectId
  business        Business @relation(fields: [businessId], references: [id])

  amount          Int      // total (including tax)
  subtotal        Int?     // before tax
  taxAmount       Int?     // Stripe tax
  taxType         String?  // GST / VAT

  currency        String
  status          String

  stripeInvoiceId String?
  invoiceNumber   String   @unique

  createdAt       DateTime @default(now())

  @@index([businessId])
  @@index([stripeInvoiceId])
}
model Analytics {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId String
  type       String
  meta       Json?
  createdAt  DateTime @default(now())
}
model reminderLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  appointmentId String
  type          String
  createdAt     DateTime @default(now())

  @@index([appointmentId, type])
}
